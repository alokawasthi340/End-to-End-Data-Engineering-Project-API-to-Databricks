{
  "datasets": [
    {
      "name": "youtube_metrics",
      "displayName": "YouTube Video Metrics",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  youtube.gold.video_performance"
      ]
    },
    {
      "name": "monthly_trends",
      "displayName": "Monthly Performance Trends",
      "queryLines": [
        "SELECT\n",
        "  DATE(CONCAT(publish_year, '-', LPAD(publish_month, 2, '0'), '-01')) AS month_date,\n",
        "  total_views,\n",
        "  total_videos,\n",
        "  avg_views\n",
        "FROM\n",
        "  youtube.gold.monthly_performance\n",
        "ORDER BY\n",
        "  publish_year,\n",
        "  publish_month"
      ]
    },
    {
      "name": "video_type_stats",
      "displayName": "Video Type Statistics",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  youtube.gold.video_type_summary"
      ]
    }
  ],
